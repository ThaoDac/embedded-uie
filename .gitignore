# =============================================================================

# -------- Python ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.ipynb_checkpoints/
*.pyo

# -------- Virtual environments ---------------------------------------------
venv/
.venv/
env/
.env/
ENV/
**/venv/
**/.venv/
**/env/
.python-version
pip-log.txt
pip-delete-this-directory.txt

# -------- IDE / OS ---------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*.iml
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

