# =============================================================================
# Sub-projects NOT part of the paper's 11 main UIE models — ignore entirely
# (Semi-UIR, TACL, UVEB are kept locally as references but excluded from git)
# =============================================================================
Semi-UIR-master/
TACL-main/
UVEB-main/
**/Semi-UIR-master/
**/TACL-main/
**/UVEB-main/

# =============================================================================
# Heavy / unused sub-folders inside the 11 main UIE models
# (legacy "origin" forks, web demo templates, paper figures, etc.)
# =============================================================================

# Origin / fork repos (lots of legacy code, scripts, .sh not used here)
FUnIE-GAN-main/FUnIE-GAN-origin/
FUnIE-GAN-main/TFKeras/
FUnIE-GAN-main/=2.16.0
LU2Net-master/LU2Net/

# Sample / training-output / qualitative-result folders inside DL models
**/samples/
**/training_output/
**/test_results/
**/qualitative_results/

# Web-demo Flask templates / static (we only use the *_console.py scripts)
UIR-PolyKernel-main/templates/
UIR-PolyKernel-main/static/
PGHS-main/templates/
PGHS-main/static/
DCP-main/templates/
DCP-main/static/
UDCP-main/templates/
UDCP-main/static/
ULAP-main/templates/
ULAP-main/static/
CLAHE-main/templates/
CLAHE-main/static/

# Paper figures / TensorBoard / experiment dirs inside DL models
WaterFormer-master/figs/
WaterFormer-master/tb_logger/
WaterFormer-master/work_dirs/
HCLR-Net-main/output/
HCLR-Net-main/r.txt

